{
  "name": "dsplat/multi-tenant-saas-module-logging",
  "version": "1.0.0",
  "description": "结构化日志 - 操作日志、安全日志、审计日志、日志查询与导出",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MultiTenantSaas\\Modules\\Logging\\": ""
    }
  },
  "require": {
    "php": "^8.3",
    "dsplat/multi-tenant-saas": "*"
  },
  "extra": {
    "saas": {
      "name": "logging",
      "priority": 5,
      "dependencies": [],
      "conflicts": [],
      "requires_core": ">=1.0.0",
      "provider": "MultiTenantSaas\\Modules\\Logging\\LoggingServiceProvider",
      "tenant_toggleable": false,
      "default_enabled": true
    }
  }
}
